---
const steps = [
  { n: "01", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`, t: "Diagnóstico inicial", d: "Revisión del estado actual del ciclo de facturación, análisis de glosas y oportunidades de mejora." },
  { n: "02", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`, t: "Diseño del plan", d: "Definición de actividades, entregables, cronograma y asignación de responsabilidades." },
  { n: "03", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`, t: "Ejecución", d: "Auditoría continua, organización de procesos, preauditoría de cuentas y gestión de glosas." },
  { n: "04", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`, t: "Seguimiento", d: "Monitoreo de indicadores, análisis de resultados y recomendaciones de mejora continua." },
];
---

<div style="margin-top:28px;">
  <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:20px;">
    {steps.map((s) => (
      <div class="card" style="padding:22px; text-align:center; position:relative;">
        <div style="width:50px; height:50px; border-radius:50%; background:linear-gradient(135deg, var(--primary), var(--secondary)); display:flex; align-items:center; justify-content:center; color:white; font-weight:900; font-size:1.1rem; margin:0 auto 14px;">
          {s.n}
        </div>
        <div style="color:var(--fg-muted); margin-bottom:8px;" set:html={s.icon} />
        <h3 style="font-size:1.05rem; font-weight:800; margin-bottom:8px;">{s.t}</h3>
        <p class="p" style="font-size:0.85rem; line-height:1.5;">{s.d}</p>

      </div>
    ))}
  </div>
</div>
